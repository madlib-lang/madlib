import IO from "IO"
import List from "List"

main = () => {
  // List literal
  nums = [1, 2, 3, 4, 5]
  IO.log(nums)

  // Map
  doubled = map((x) => x * 2, nums)
  IO.log(doubled)

  // Filter
  evens = List.filter((x) => x % 2 == 0, nums)
  IO.log(evens)

  // Reduce
  sum = List.reduceLeft((acc, x) => acc + x, 0, nums)
  IO.log(sum)

  // Length
  IO.log(List.length(nums))

  // Head and tail
  IO.log(List.nth(0, nums))
  IO.log(List.tail(nums))

  // Last and init
  IO.log(List.last(nums))
  IO.log(List.init(nums))

  // Sort
  unsorted = [5, 3, 1, 4, 2]
  IO.log(List.sort(unsorted))

  // Find
  found = List.find((x) => x > 3, nums)
  IO.log(found)
  notFound = List.find((x) => x > 10, nums)
  IO.log(notFound)

  // Flatten
  nested = [[1, 2], [3, 4], [5]]
  IO.log(List.flatten(nested))

  // Slice
  IO.log(List.slice(1, 3, nums))

  // Empty list
  empty = ([] :: List Integer)
  IO.log(empty)
  IO.log(List.length(empty))

  // List spread in construction
  base = [1, 2, 3]
  extended = [0, ...base, 4, 5]
  IO.log(extended)

  // Map with index
  indexed = List.mapWithIndex((x, i) => x * 10 + i, [1, 2, 3])
  IO.log(indexed)
}
