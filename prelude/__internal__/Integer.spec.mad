import { EQ, LT, GT } from "Compare"
import { assertEquals, test } from "Test"
import { Just } from "Maybe"


// Comparison
test("Compare Integer - GT", () => assertEquals(compare(3, 2), GT))
test("Compare Integer - LT", () => assertEquals(compare(1, 2), LT))
test("Compare Integer - EQ", () => assertEquals(compare(2, 2), EQ))

// Equality
test("Eq Integer - equal", () => assertEquals(3 == 3, true))
test("Eq Integer - not equal", () => assertEquals(3 == 4, false))

// Arithmetic
test("addition", () => assertEquals(3 + 4, 7))
test("subtraction", () => assertEquals(10 - 3, 7))
test("multiplication", () => assertEquals(3 * 4, 12))
test("unary minus", () => assertEquals(-5, 0 - 5))
test("modulo", () => assertEquals(10 % 3, 1))

// Bitwise operations
test("bitwise and", () => assertEquals(12 & 10, 8))
test("bitwise or", () => assertEquals(12 | 10, 14))
test("bitwise xor", () => assertEquals(12 ^ 10, 6))
test("left shift", () => assertEquals(1 << 4, 16))
test("right shift", () => assertEquals(16 >> 2, 4))

// Show
test("show Integer", () => assertEquals(show(42), "42"))
test("show Integer - negative", () => assertEquals(show(-42), "-42"))
test("show Integer - zero", () => assertEquals(show(0), "0"))

// Scan
test("scan Integer - valid", () => assertEquals(scan("42"), Just(42)))
test("scan Integer - negative", () => assertEquals(scan("-7"), Just(-7)))
test("scan Integer - invalid", () => assertEquals(scan("abc") == Just(0), false))
test("scan Integer - reject trailing chars", () => assertEquals(scan("12abc") == Just(12), false))
test("scan Integer - reject overflow", () => assertEquals(scan("999999999999999999999999") == Just(9223372036854775807), false))
test("scan Integer - reject negative with trailing chars", () => assertEquals(scan("-7x") == Just(-7), false))
test("scan Integer - reject leading whitespace", () => assertEquals(scan(" 42") == Just(42), false))
